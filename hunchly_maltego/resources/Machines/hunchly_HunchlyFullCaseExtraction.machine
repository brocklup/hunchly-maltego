//Welcome to Maltego Machines!

machine("hunchly.HunchlyFullCaseExtraction", 
        displayName:"Hunchly Full Case Extraction", 
        author:"Hunchly",
        description: "Walks through a case and retrieves all pages, selectors, extracted data and photos.") {

    start {
        run("getpages")

        paths{
            run("getdata")
            run("getselectors")
            path{
                run("getphotos")
                run("getphotoexif")
            }
        }
    }
}
